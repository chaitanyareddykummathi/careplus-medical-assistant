DB_URL=postgresql://user:password@localhost/careplus
APP_NAME=CarePlus Medical Assistant
APP_ENV=development
APP_DEBUG=false
API_V1_PREFIX=/api/v1

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=30
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
CORS_ALLOW_ORIGINS=http://localhost:3000

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

CACHE_TTL_SECONDS=300
ANALYSIS_JOB_MAX_RETRIES=3
ANALYSIS_RETRY_BACKOFF_SECONDS=20
ANALYSIS_RATE_LIMIT_PER_MINUTE=30
ANALYSIS_WORKER_BATCH_SIZE=8
WORKER_HEALTH_TIMEOUT_SECONDS=2

LOG_LEVEL=INFO
TRACING_ENABLED=true

MEDICAL_NER_MODEL=en_ner_bc5cdr_md
CLASSIFIER_MODEL=distilbert-base-uncased-finetuned-sst-2-english
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
MODEL_VERSION_TAG=v1
NLP_BATCH_SIZE=8
NLP_WARMUP_ENABLED=true

VECTOR_IVFFLAT_LISTS=100
VECTOR_IVFFLAT_PROBES=10
REACT_APP_API_BASE_URL=https://api.careplus.example.com/api/v1
